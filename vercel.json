{
  "rewrites": [
    {
      "source": "/produto/:id",
      "destination": "/produto.html?id=:id"
    },
    {
      "source": "/produto/:id/",
      "destination": "/produto.html?id=:id"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/checkout/",
      "destination": "/checkout.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}